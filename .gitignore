# ===========================
# Root-level .gitignore for salary-coach monorepo
# ===========================

# Dependencies (both client & server)
node_modules/

# Environment Variables (NEVER commit!)
.env
.env.*
!.env.example

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Editor & IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Logs
*.log
logs/
